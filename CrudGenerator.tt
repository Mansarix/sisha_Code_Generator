var importCsvView = $@"
{commonStyles}

<div class=""container py-5"" dir=""rtl"">
    <div class=""row justify-content-center"">
        <div class=""col-md-8"">
            <div class=""card shadow-lg"">
                <div class=""card-header bg-secondary text-white p-4 border-0"">
                    <h5 class=""mb-0 fw-bold"">ایمپورت داده‌ها از فایل CSV ({model})</h5>
                </div>
                <div class=""card-body p-4 p-md-5"">
                    
                    <div class=""alert alert-info border-start border-info border-4 shadow-sm mb-4"">
                        <h6 class=""alert-heading fw-bold"">راهنمای ایمپورت</h6>
                        <p class=""mb-0"">دقت کنید که سطر اول فایل CSV حتماً باید شامل نام دقیق فیلدهای جدول (به انگلیسی) باشد. شناسه‌ها (Id) در نظر گرفته نمی‌شوند.</p>
                    </div>

                    <form method=""post"" enctype=""multipart/form-data"" action=""/{model}/ImportCsv"">
                        <div class=""mb-4 p-4 border border-dashed rounded bg-light text-center hover-effect"">
                            <label class=""form-label fw-bold d-block mb-3"">فایل CSV خود را انتخاب کنید</label>
                            <input type=""file"" name=""file"" class=""form-control form-control-lg mx-auto"" style=""max-width: 400px;"" accept="".csv"" required />
                        </div>
                        
                        <hr class=""my-4"">
                        <div class=""d-flex gap-2"">
                            <button type=""submit"" class=""btn btn-primary btn-lg px-5 shadow-sm"">شروع ایمپورت داده‌ها</button>
                            <a class=""btn btn-light border btn-lg px-4"" href=""/{model}"">انصراف</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
";
File.WriteAllText(Path.Combine(views,model,"ImportCsv.cshtml"),importCsvView);

di.AppendLine($"services.AddScoped<I{model}Repository, {model}Repository>();");
di.AppendLine($"services.AddScoped<I{model}Service, {model}Service>();");

}


// --- تولید فایل پیکربندی XML برای منوها ---
var xml = new StringBuilder();
xml.AppendLine("<?xml version=\"1.0\" encoding=\"utf-8\"?>");
xml.AppendLine("<AdminConfig>");
xml.AppendLine("  <MenuItems>");
xml.AppendLine("    <Menu Title=\"داشبورد\" Url=\"/Home/Index\" Icon=\"🏠\" />");
foreach(var m in generatedModels)
{
    xml.AppendLine($"    <Menu Title=\"{m}\" Url=\"/{m}/Index\" Icon=\"📁\" />");
}
xml.AppendLine("  </MenuItems>");
xml.AppendLine("</AdminConfig>");

File.WriteAllText(Path.Combine(root, "admin-config.xml"), xml.ToString());
